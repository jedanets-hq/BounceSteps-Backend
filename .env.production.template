# Production Environment Variables Template
# Copy this to .env.production and fill in your actual values
# NEVER commit .env.production to git!

NODE_ENV=production
PORT=8080

# Production Database Configuration (Cloud SQL)
DB_HOST=your-cloud-sql-instance-ip
DB_PORT=5432
DB_USER=your-db-user
DB_PASSWORD=your-secure-db-password
DB_NAME=bouncesteps-production-db

# Or use DATABASE_URL (recommended for Cloud SQL)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Security Configuration (GENERATE NEW SECRETS!)
SESSION_SECRET=generate-a-strong-random-secret-here
JWT_SECRET=generate-another-strong-random-secret-here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Production URLs
GOOGLE_CALLBACK_URL=https://api.bouncesteps.com/api/auth/google/callback
FRONTEND_URL=https://bouncesteps.com
FRONTEND_URL_WWW=https://www.bouncesteps.com
FRONTEND_URL_MAIN=https://bouncesteps.com

# CORS Origins (Production)
CORS_ORIGINS=https://bouncesteps.com,https://www.bouncesteps.com,https://admin.bouncesteps.com
